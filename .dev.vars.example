# Copy this file to .dev.vars and fill in real values.
# .dev.vars is gitignored — never commit it.
# This is the single source of truth for local dev AND smoke tests.

# Secrets — required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # Must be the service_role key, NOT the anon key. Find under Project Settings → API → service_role (click Reveal).
SUPABASE_DB_PASSWORD=your_database_password_here   # Only needed for `supabase link`; deploy script uses --linked mode

# Whitelist — comma-separated Telegram chat IDs allowed to use the bot.
# Find your chat ID: message the bot, then curl
# https://api.telegram.org/bot{TOKEN}/getUpdates and look at message.chat.id
ALLOWED_CHAT_IDS=your_chat_id_here

# MCP Worker — generate with: openssl rand -hex 32
MCP_API_KEY=your_mcp_api_key_here

# Gardener Worker — generate with: openssl rand -hex 32
# Enables POST /trigger endpoint for manual runs and smoke tests.
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are shared with the main Worker above.
# GARDENER_SIMILARITY_THRESHOLD is set in gardener/wrangler.toml [vars] — default 0.70.
GARDENER_API_KEY=your_gardener_api_key_here

# OAuth consent page secret — generate with: openssl rand -hex 16
CONSENT_SECRET=your_consent_secret_here

# KV namespace IDs (reference only — paste into mcp/wrangler.toml after creating)
# Create with: wrangler kv namespace create OAUTH_KV -c mcp/wrangler.toml
#              wrangler kv namespace create OAUTH_KV --preview -c mcp/wrangler.toml
OAUTH_KV_ID=your_kv_namespace_id_here
OAUTH_KV_PREVIEW_ID=your_kv_preview_id_here

# Test-only — not used by the worker itself
WORKER_URL=https://contemplace.your-subdomain.workers.dev
TELEGRAM_CHAT_ID=your_chat_id_here
MCP_WORKER_URL=https://mcp-contemplace.your-subdomain.workers.dev
GARDENER_WORKER_URL=https://contemplace-gardener.your-subdomain.workers.dev
